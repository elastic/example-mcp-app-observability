{
  "name": "example-mcp-app-observability",
  "version": "1.0.7",
  "description": "MCP App server for Elastic Observability — interactive SRE workflows for Kubernetes incident investigation, ML anomaly triage, blast-radius assessment, remediation, and alert-rule management (create, list, get, delete)",
  "type": "module",
  "license": "Elastic-2.0",
  "main": "dist/main.js",
  "bin": {
    "example-mcp-app-observability": "./dist/main.js"
  },
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/elastic/example-mcp-app-observability.git"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "elastic",
    "elasticsearch",
    "kibana",
    "observability",
    "sre",
    "kubernetes",
    "opentelemetry",
    "otel",
    "apm",
    "ml-anomalies"
  ],
  "scripts": {
    "build": "tsc --noEmit && tsc -p tsconfig.server.json && node scripts/build-views.js",
    "build:views": "node scripts/build-views.js",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/main.js",
    "start:stdio": "node dist/main.js --stdio",
    "dev": "concurrently --raw \"node scripts/build-views.js --watch\" \"tsx watch main.ts\"",
    "typecheck": "tsc --noEmit",
    "audit:fields": "tsx scripts/audit-fields.ts",
    "mcpb:pack": "bash scripts/build-mcpb.sh",
    "skills:zip": "bash scripts/build-skill-zips.sh",
    "prepublishOnly": "npm run build",
    "version": "node -e \"const m=JSON.parse(require('fs').readFileSync('manifest.json','utf8'));m.version=require('./package.json').version;require('fs').writeFileSync('manifest.json',JSON.stringify(m,null,2)+'\\n')\" && git add manifest.json"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.3.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vite-plugin-singlefile": "^2.3.2"
  }
}
